{
  "manifest_version": 3,
  "name": "RavenDark Sheets to Roll20",
  "version": "0.1.0",
  "description": "Add Roll buttons on RavenDark character sheets and send roll commands to Roll20 chat.",
  "browser_specific_settings": {
    "gecko": {
      "id": "{024354d9-8d6c-4150-b17a-ef29cb781326}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://ravendark-sheets.vercel.app/characters/*",
    "https://app.roll20.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://ravendark-sheets.vercel.app/characters/*"],
      "js": ["content-ravendark.js"],
      "css": ["content-ravendark.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://app.roll20.net/*"],
      "js": ["content-roll20.js"],
      "run_at": "document_end"
    }
  ]
}
